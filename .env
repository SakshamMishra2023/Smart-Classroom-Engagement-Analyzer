# ==============================================================
# SMART CLASSROOM ANALYZER - ENVIRONMENT VARIABLES
# Copy this file to .env.local and update values for your environment
# ==============================================================

# --- Application Setup ---
VITE_ENV=development
VITE_APP_NAME="Smart Classroom Engagement Analyzer"
VITE_APP_VER="1.0.0"

# --- Backend API Endpoints ---
# The base URL where the backend APIs (Node/Python/Django/etc) are hosted
VITE_API_BASE_URL=http://localhost:5000/api
# Specific endpoint for querying course rosters and student DB lists
VITE_API_COURSES_ENDPOINT=/courses
# Specific endpoint for querying historic lecture sessions
VITE_API_LECTURES_ENDPOINT=/lectures

# --- Roboflow Integration ---
# Your secret API key from roboflow.com workspace settings
VITE_ROBOFLOW_API_KEY=your_roboflow_secret_key_here
# The workspace URL/slug in Roboflow
VITE_ROBOFLOW_WORKSPACE=classroom-analytics-ws
# The Model ID or Project URL slug
VITE_ROBOFLOW_MODEL=student-engagement-detection
# Version of the model to run inference against (e.g. 1)
VITE_ROBOFLOW_VERSION=3

# --- File Uploads / Video Processors ---
# Maximum allowable video file size for frontend upload widget (in Bytes; here 500MB)
VITE_MAX_UPLOAD_SIZE_BYTES=524288000
# S3 or Blob storage endpoint if storing video chunks directly from frontend
VITE_STORAGE_BUCKET_URL=https://s3.amazonaws.com/your-bucket/
