PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/classroom_vision
JWT_SECRET=CV_PROJECT
JWT_EXPIRES_IN=7d
FRONTEND_ORIGIN=http://localhost:5173

ROBOFLOW_API_KEY=replace-with-your-roboflow-api-key
ROBOFLOW_MODEL_URL=https://serverless.roboflow.com/student-behaviour-detection-neazg/1

# Optional safety cap. Leave blank to analyze one frame per second for the full video.
# MAX_VIDEO_SECONDS=60

# Mode B live simulation. Put your video here or point to an absolute path.
MODE_B_VIDEO_PATH=./simulation/mode-b-video.mp4
MODE_B_FRAME_DELAY_MS=1000
# Optional safety cap for long videos.
# MODE_B_MAX_SECONDS=120

# Optional if ffmpeg/ffprobe are installed manually and you do not use ffmpeg-static.
# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
# FFPROBE_PATH=C:\ffmpeg\bin\ffprobe.exe

# Cloudinary credentials for uploading Mode B evidence images.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
